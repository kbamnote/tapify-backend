{
  "type": "services",
  "label": "Services",
  "category": "content",
  "icon": "grid-3x3",
  "description": "Grid or list of services / courses / offerings, each with an image, title and description.",
  "industries": ["*"],
  "singleton": false,
  "maxPerPage": 3,

  "variants": [
    { "id": "cards-3",   "label": "3-column cards",  "preview": "/builder/previews/services-cards-3.png" },
    { "id": "cards-2",   "label": "2-column cards",  "preview": "/builder/previews/services-cards-2.png" },
    { "id": "cards-4",   "label": "4-column cards",  "preview": "/builder/previews/services-cards-4.png" },
    { "id": "list",      "label": "Icon list",       "preview": "/builder/previews/services-list.png" },
    { "id": "carousel",  "label": "Carousel",        "preview": "/builder/previews/services-carousel.png" },
    { "id": "marquee",   "label": "Marquee (auto-scroll)", "preview": "/builder/previews/services-marquee.png" }
  ],

  "props": [
    { "key": "label",   "type": "text",     "label": "Eyebrow label", "maxLength": 40, "default": "Our Services", "group": "Heading" },
    { "key": "heading", "type": "text",     "label": "Heading", "required": true, "maxLength": 120, "group": "Heading" },
    { "key": "sub",     "type": "textarea", "label": "Description", "maxLength": 300, "group": "Heading" },

    {
      "key": "items",
      "type": "repeater",
      "label": "Services",
      "group": "Items",
      "min": 1,
      "max": 24,
      "itemLabel": "{{title}}",
      "addLabel": "Add service",
      "fields": [
        { "key": "image",  "type": "media",    "label": "Image", "accept": ["image"] },
        { "key": "icon",   "type": "icon",     "label": "Icon", "help": "Used by the Icon list variant.",
          "showIf": { "variant": ["list"] } },
        { "key": "title",  "type": "text",     "label": "Title", "required": true, "maxLength": 80 },
        { "key": "desc",   "type": "textarea", "label": "Description", "maxLength": 300 },
        { "key": "meta",   "type": "text",     "label": "Meta line", "maxLength": 60, "placeholder": "e.g. 2 Years · Class 11-12" },
        { "key": "cta",    "type": "link",     "label": "Button" },

        { "key": "body",   "type": "textarea", "label": "Full description (opens its own page)", "maxLength": 20000,
          "help": "Fill this to give the service/product its own detail page with a photo gallery — like a product page on Amazon or Flipkart. The card's Button, if set, is ignored and 'View details' is shown instead." },
        { "key": "gallery", "type": "repeater", "label": "Photos (for the detail page)", "max": 10, "itemLabel": "{{alt}}", "addLabel": "Add photo",
          "fields": [
            { "key": "image", "type": "media", "label": "Photo", "accept": ["image"], "required": true },
            { "key": "alt",   "type": "text",  "label": "Caption", "maxLength": 120 }
          ]
        },
        { "key": "productInfoTitle", "type": "text", "label": "Info table title", "maxLength": 60, "placeholder": "Product Information",
          "help": "Only used when the rows below are filled in." },
        { "key": "productInfo", "type": "repeater", "label": "Product information (optional)", "max": 20,
          "itemLabel": "{{label}}", "addLabel": "Add row",
          "help": "A spec table on the detail page — Brand, Material, Pack of, and so on. Leave empty to hide it.",
          "fields": [
            { "key": "label", "type": "text", "label": "Label", "maxLength": 60, "placeholder": "e.g. Material" },
            { "key": "value", "type": "text", "label": "Value", "maxLength": 200, "placeholder": "e.g. MDF, Printed Vinyl" }
          ]
        },
        { "key": "price",  "type": "text",     "label": "Selling price", "maxLength": 40, "placeholder": "e.g. ₹4,999" },
        { "key": "mrp",    "type": "text",     "label": "MRP (crossed out)", "maxLength": 40, "placeholder": "e.g. ₹7,999",
          "help": "Shown struck through next to the selling price, with the discount %." },
        { "key": "variantLabel",   "type": "text", "label": "Option name", "maxLength": 40, "placeholder": "Size / Weight / Volume",
          "help": "Adds a choice the buyer must pick, like Size or 250ml." },
        { "key": "variantOptions", "type": "list", "label": "Option choices",
          "help": "e.g. S, M, L  —  or 100ml, 250ml, 500ml." },
        { "key": "enableOrder", "type": "toggle", "label": "Allow ordering (Add to Cart / Buy Now)", "default": true },
        { "key": "slug",   "type": "text",     "label": "Page address (optional)", "maxLength": 80, "placeholder": "auto from title",
          "help": "The detail page address: /service/<this>. Leave blank to build it from the title." }
      ]
    },
    { "key": "showRelated", "type": "toggle", "label": "Show other products on the detail page", "default": true, "group": "Detail page",
      "help": "Adds a \"Best sellers\" strip under each product so visitors can jump to your other items." },
    { "key": "relatedHeading", "type": "text", "label": "That strip's heading", "maxLength": 60, "default": "Best sellers", "group": "Detail page" },

    { "key": "imageFit", "type": "crop",   "label": "Crop / position", "group": "Media",
      "help": "Drag the photo to choose what stays in frame, and zoom in to crop closer." }
  ],

  "style": {
    "supports": ["paddingY", "align", "bg", "bgMedia", "overlay", "radius", "animation", "headingColor", "textColor"],
    "defaults": { "paddingY": "lg", "align": "center", "bg": "default" }
  },

  "defaults": {
    "variant": "cards-3",
    "props": {
      "label": "Our Services",
      "heading": "What we offer",
      "items": [
        { "title": "Service one", "desc": "Short description of this service." },
        { "title": "Service two", "desc": "Short description of this service." },
        { "title": "Service three", "desc": "Short description of this service." }
      ]
    }
  }
}
