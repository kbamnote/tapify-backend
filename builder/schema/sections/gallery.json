{
  "type": "gallery",
  "label": "Gallery",
  "category": "media",
  "icon": "images",
  "description": "Photo gallery — grid, masonry, slider or lightbox.",
  "industries": ["*"],
  "singleton": false,
  "maxPerPage": 3,

  "variants": [
    { "id": "grid-3",  "label": "3-column grid", "preview": "/builder/previews/gallery-grid-3.png" },
    { "id": "grid-4",  "label": "4-column grid", "preview": "/builder/previews/gallery-grid-4.png" },
    { "id": "masonry", "label": "Masonry",       "preview": "/builder/previews/gallery-masonry.png" },
    { "id": "slider",  "label": "Slider",        "preview": "/builder/previews/gallery-slider.png" },
    { "id": "marquee", "label": "Marquee (auto-scroll)", "preview": "/builder/previews/gallery-marquee.png" }
  ],

  "props": [
    { "key": "label",    "type": "text",     "label": "Eyebrow label", "maxLength": 40, "default": "Gallery", "group": "Heading" },
    { "key": "heading",  "type": "text",     "label": "Heading", "maxLength": 120, "group": "Heading" },
    { "key": "sub",      "type": "textarea", "label": "Description", "maxLength": 300, "group": "Heading" },

    {
      "key": "images",
      "type": "repeater",
      "label": "Images",
      "group": "Images",
      "max": 60,
      "itemLabel": "{{alt}}",
      "addLabel": "Add image",
      "fields": [
        { "key": "image", "type": "media", "label": "Image", "accept": ["image"], "required": true },
        { "key": "alt",   "type": "text",  "label": "Caption / alt text", "maxLength": 120,
          "help": "Describes the photo — shown as a caption and used by search engines." }
      ],
      "emptyHint": "Add photos to show this gallery. A gallery with no photos is hidden on the live site."
    },

    { "key": "lightbox", "type": "toggle", "label": "Open full size on click", "default": true, "group": "Behaviour" }
  ],

  "style": {
    "supports": ["paddingY", "align", "bg", "bgMedia", "overlay", "radius", "animation"],
    "defaults": { "paddingY": "lg", "align": "center", "bg": "surface", "radius": "lg" }
  },

  "defaults": {
    "variant": "grid-3",
    "props": {
      "label": "Gallery",
      "heading": "A look inside",
      "lightbox": true,
      "images": []
    }
  }
}
