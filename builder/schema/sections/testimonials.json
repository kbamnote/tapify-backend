{
  "type": "testimonials",
  "label": "Testimonials",
  "category": "social-proof",
  "icon": "quote",
  "description": "What customers say — quotes with name, photo and rating.",
  "industries": ["*"],
  "singleton": false,
  "maxPerPage": 2,

  "variants": [
    { "id": "cards-3",  "label": "3-column cards", "preview": "/builder/previews/testimonials-cards-3.png" },
    { "id": "slider",   "label": "Slider",         "preview": "/builder/previews/testimonials-slider.png" },
    { "id": "single",   "label": "One big quote",  "preview": "/builder/previews/testimonials-single.png" },
    { "id": "marquee",  "label": "Marquee (auto-scroll)", "preview": "/builder/previews/testimonials-marquee.png" }
  ],

  "props": [
    { "key": "label",   "type": "text",     "label": "Eyebrow label", "maxLength": 40, "default": "Testimonials", "group": "Heading" },
    { "key": "heading", "type": "text",     "label": "Heading", "maxLength": 120, "group": "Heading" },
    { "key": "sub",     "type": "textarea", "label": "Description", "maxLength": 300, "group": "Heading" },

    {
      "key": "items",
      "type": "repeater",
      "label": "Reviews",
      "group": "Reviews",
      "min": 1,
      "max": 30,
      "itemLabel": "{{name}}",
      "addLabel": "Add review",
      "fields": [
        { "key": "quote",  "type": "textarea", "label": "Review", "required": true, "maxLength": 600 },
        { "key": "name",   "type": "text",     "label": "Name", "required": true, "maxLength": 80 },
        { "key": "role",   "type": "text",     "label": "Role / context", "maxLength": 80, "placeholder": "e.g. NEET 2024 Qualifier" },
        { "key": "photo",  "type": "media",    "label": "Photo", "accept": ["image"] },
        { "key": "rating", "type": "number",   "label": "Rating (1-5)", "min": 1, "max": 5, "default": 5 }
      ]
    },

    { "key": "autoplay", "type": "toggle", "label": "Auto-advance", "default": true, "group": "Behaviour",
      "showIf": { "variant": ["slider"] } }
  ],

  "style": {
    "supports": ["paddingY", "align", "bg", "bgMedia", "overlay", "radius", "animation"],
    "defaults": { "paddingY": "lg", "align": "center", "bg": "surface" }
  },

  "defaults": {
    "variant": "cards-3",
    "props": {
      "label": "Testimonials",
      "heading": "What our customers say",
      "items": [
        { "quote": "Genuinely great experience from start to finish.", "name": "Customer name", "rating": 5 }
      ]
    }
  }
}
