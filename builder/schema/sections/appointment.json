{
  "type": "appointment",
  "label": "Appointment",
  "category": "contact",
  "icon": "calendar-clock",
  "description": "A booking request form. Submissions open directly in WhatsApp or email — no backend needed.",
  "industries": ["*"],
  "singleton": false,
  "maxPerPage": 1,

  "variants": [
    { "id": "form",        "label": "Form only" },
    { "id": "image-left",  "label": "Image left, form right" },
    { "id": "image-right", "label": "Image right, form left" }
  ],

  "props": [
    { "key": "label",   "type": "text",     "label": "Eyebrow label", "maxLength": 40, "default": "Booking", "group": "Heading" },
    { "key": "heading", "type": "text",     "label": "Heading", "maxLength": 120, "default": "Book an appointment", "group": "Heading" },
    { "key": "sub",     "type": "textarea", "label": "Description", "maxLength": 300, "group": "Heading" },

    { "key": "alsoNotify", "type": "select", "label": "After booking, also open", "default": "whatsapp",
      "options": ["whatsapp", "email", "none"], "group": "Delivery",
      "help": "Every request is saved to your Appointments page. This additionally opens a pre-filled WhatsApp chat or email using your Business Info." },
    { "key": "submitText", "type": "text", "label": "Button text", "maxLength": 40, "default": "Request appointment", "group": "Delivery" },

    { "key": "services", "type": "list", "label": "Services to choose from", "group": "Options",
      "help": "Adds a Service dropdown. When you list services here, choosing one becomes compulsory." },

    { "key": "image", "type": "media", "label": "Image", "accept": ["image"], "group": "Media",
      "showIf": { "variant": ["image-left", "image-right"] } },
    { "key": "imageFit", "type": "crop",   "label": "Crop / position", "group": "Media",
      "showIf": { "variant": ["image-left", "image-right"] } }
  ],

  "style": {
    "supports": ["paddingY", "align", "bg", "bgMedia", "overlay", "radius", "animation", "headingColor", "textColor"],
    "defaults": { "paddingY": "lg", "align": "center", "bg": "surface" }
  },

  "defaults": {
    "variant": "form",
    "props": {
      "label": "Booking",
      "heading": "Book an appointment",
      "sub": "Pick a time that suits you and we'll confirm shortly.",
      "alsoNotify": "whatsapp",
      "submitText": "Request appointment"
    }
  }
}
